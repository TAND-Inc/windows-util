# Absolute path on the Docker host to the private LAN script source folder.
# This should point to a NAS-mounted or private local folder that already exists.
# The compose file uses create_host_path: false, so a missing path fails instead
# of silently creating and serving an empty folder.
LAN_SCRIPT_SOURCE=/mnt/windows-util-scripts

# Published host port for the LAN-only Caddy server.
LAN_SCRIPT_PORT=8085
